# Copy to `.env.local` and fill in. Vite only exposes vars prefixed with VITE_.

# Backend API base URL (no trailing slash). Prepended to every path in
# src/lib/api/endpoints.ts.
VITE_API_BASE=http://localhost:8000/api

# Data source switch:
#   true  (default) → in-memory mocks from src/lib/mocks/* (no backend needed)
#   false           → real HTTP calls to VITE_API_BASE
VITE_USE_MOCKS=true
